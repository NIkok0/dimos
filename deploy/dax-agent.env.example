# DimOS dax-agent real-robot configuration template.
# Copy to .env next to pyproject.toml and fill in real values.
#   cp deploy/dax-agent.env.example .env && vim .env
# GlobalConfig (pydantic-settings) reads this automatically on import.

# ─── LLM ───────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-replace-me
DAX_AGENT_MODEL=deepseek-v4-pro

# ─── dax_server HTTP joint control (head_accept/reject/wave) ───────────────
DAX_JOINT_SERVER_URL=http://10.69.6.144:5000
DAX_JOINT_REQUEST_TIMEOUT_S=30.0
# Wave keyframe JSON ({"positions": [[7 floats], ...]}). Ship to the robot.
DAX_WAVE_ANIMATION_PATH=/opt/dax-agent/data/dax_hi_ani.json

# ─── rosbridge gRPC (navigation / pick via py_rosbridge) ───────────────────
ROSBIDGE_GRPC_TARGET=10.69.6.144:9091
ROSBIDGE_READY_TIMEOUT_S=10
VLA_PICK_ADAPTER=py_rosbridge
VLA_ROS_ADAPTER=py_rosbridge
VLA_SYS_NAV_ADAPTER=ros_topic
ROS_NAV_WORKSPACE_CATALOG=/opt/dax-agent/config/workspaces.yaml
ROS_NAV_MAP_TOPIC=/map
ROS_NAV_MAP_TOPIC_TYPE=nav_msgs/msg/OccupancyGrid
ROS_NAV_SLAM_STATUS_TOPIC=/slam_status
ROS_NAV_SLAM_STATUS_TOPIC_TYPE=robot_interfaces/msg/SlamStatus
ROS_NAV_STATUS_TOPIC=/navigation_current_status
ROS_NAV_STATUS_TOPIC_TYPE=robot_interfaces/msg/NavStatus
ROS_NAVIGATE_TO_POSE_ACTION=/navigate_to_pose
ROS_NAVIGATE_TO_POSE_ACTION_TYPE=robot_interfaces/action/NavigateToPose
ROS_NAV_DEFAULT_FRAME_ID=map
ROS_NAV_ACTION_TIMEOUT_S=60
ROS_NAV_LOCALIZATION_TIMEOUT_S=5
ROS_NAV_TARGET_SAFETY_RADIUS_M=0.01
ROS_GO_TO_WORKSPACE_SERVICE=/go_to_workspace
ROS_GO_TO_WORKSPACE_SERVICE_TYPE=dax_dimos_interfaces/srv/GoToWorkspace
ROS_PICK_SKU_SERVICE=/pick_sku
ROS_PICK_SKU_SERVICE_TYPE=dax_dimos_interfaces/srv/PickSku
ROS_EXECUTE_PICK_TASK_SERVICE=/execute_pick_task
ROS_EXECUTE_PICK_TASK_SERVICE_TYPE=dax_dimos_interfaces/srv/ExecutePickTask
ROS_RUN_DEMO_SERVICE=/run_demo
ROS_RUN_DEMO_SERVICE_TYPE=dax_dimos_interfaces/srv/RunDemo
ROS_RESET_SCENE_SERVICE=/reset_scene
ROS_RESET_SCENE_SERVICE_TYPE=dax_dimos_interfaces/srv/Trigger
ROS_GET_STATE_SERVICE=/get_state
ROS_GET_STATE_SERVICE_TYPE=dax_dimos_interfaces/srv/Trigger
ROS_ACTION_TIMEOUT_S=30

# ─── MCP HTTP server (exposes skills to external clients) ──────────────────
MCP_PORT=9990
# Bind on all interfaces so other machines can reach MCP. Default 127.0.0.1
# only allows localhost. Change to 127.0.0.1 if MCP clients run on the robot.
LISTEN_HOST=0.0.0.0

# ─── /vis/* demo frontend bridge (optional) ────────────────────────────────
# Empty = bridge disabled (no-op). Set to push user input / reasoning /
# final reply to a colleague's stop-and-wait REST frontend for visualization.
VIS_BRIDGE_URL=
VIS_BRIDGE_TIMEOUT_S=30
VIS_BRIDGE_MAX_RETRIES=3

# ─── Dax Skill SDK (optional, disabled by default) ─────────────────────────
DAX_SKILL_ADAPTER=disabled
